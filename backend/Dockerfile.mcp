# MCP Server Dockerfile
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY ["Mizan.Mcp.Server/Mizan.Mcp.Server.csproj", "Mizan.Mcp.Server/"]
RUN dotnet restore "Mizan.Mcp.Server/Mizan.Mcp.Server.csproj"

COPY Mizan.Mcp.Server/ Mizan.Mcp.Server/
RUN dotnet publish "Mizan.Mcp.Server/Mizan.Mcp.Server.csproj" -c Release -o /app/publish

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS final
WORKDIR /app
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*
COPY --from=build /app/publish .

EXPOSE 5001
ENV ASPNETCORE_URLS=http://+:5001
ENTRYPOINT ["dotnet", "Mizan.Mcp.Server.dll"]
